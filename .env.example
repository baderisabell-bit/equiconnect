# Database (preferred for deployment, e.g. Vercel)
DATABASE_URL=postgres://user:password@host:5432/database

# Database (local fallback)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=equipro
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=disable

# Public app URL (used for reset links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP (password reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Equily <noreply@your-domain.com>"
CONTACT_TO_EMAIL=support@your-domain.com

# Admin panel protection
ADMIN_PANEL_CODE=

# Cron authentication (use a long random value in production)
CRON_SECRET=choose_a_long_random_secret
SUBSCRIPTION_INVOICE_CRON_TOKEN=

